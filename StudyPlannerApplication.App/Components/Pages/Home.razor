@page "/Home"
@using StudyPlannerApplication.App.Components.Layout
@layout MainLayout

<div class="flex flex-col items-center justify-center min-h-[60vh] text-center space-y-8 animate-in fade-in zoom-in duration-700">
    <div class="space-y-4">
        <h1 class="text-5xl font-extrabold tracking-tight lg:text-6xl text-primary">
            Master Your Studies
        </h1>
        <p class="text-xl text-muted-foreground max-w-[600px]">
            Organize your subjects, track your courses, and never miss an exam with the ultimate Study Planner.
        </p>
    </div>

    <div class="flex gap-4">
        <a href="/dashboard" class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors bg-primary text-primary-foreground hover:bg-primary/90 h-11 px-8">
            Go to Dashboard
        </a>
        <a href="/subject" class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors border border-input bg-background hover:bg-accent hover:text-accent-foreground h-11 px-8">
            Manage Subjects
        </a>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8 mt-16 w-full max-w-5xl">
        <div class="p-6 bg-card border border-border rounded-xl shadow-sm space-y-2">
            <div class="w-10 h-10 bg-primary/10 text-primary flex items-center justify-center rounded-lg mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-book"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H20v20H6.5a2.5 2.5 0 0 1-2.5-2.5Z"/><path d="M8 5v3"/><path d="M12 5v3"/><path d="M16 5v3"/></svg>
            </div>
            <h3 class="text-lg font-bold">Smart Subjects</h3>
            <p class="text-sm text-muted-foreground">Keep all your study materials organized by subject and topic.</p>
        </div>
        <div class="p-6 bg-card border border-border rounded-xl shadow-sm space-y-2">
            <div class="w-10 h-10 bg-primary/10 text-primary flex items-center justify-center rounded-lg mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-calendar"><rect width="18" height="18" x="3" y="4" rx="2" ry="2"/><line x1="16" x2="16" y1="2" y2="6"/><line x1="8" x2="8" y1="2" y2="6"/><line x1="3" x2="21" y1="10" y2="10"/></svg>
            </div>
            <h3 class="text-lg font-bold">Planned Progress</h3>
            <p class="text-sm text-muted-foreground">Track your learning journey with interactive dashboards and reminders.</p>
        </div>
        <div class="p-6 bg-card border border-border rounded-xl shadow-sm space-y-2">
            <div class="w-10 h-10 bg-primary/10 text-primary flex items-center justify-center rounded-lg mb-4">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="lucide lucide-shield-check"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10Z"/><path d="m9 12 2 2 4-4"/></svg>
            </div>
            <h3 class="text-lg font-bold">Exam Ready</h3>
            <p class="text-sm text-muted-foreground">Stay on top of your exam dates and preparation levels.</p>
        </div>
    </div>
</div>
