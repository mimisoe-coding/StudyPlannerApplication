@page "/settings/theme"
@using StudyPlannerApplication.App.Services
@implements IDisposable
@inject ThemeService themeService
@inject IJSRuntime JSRuntime
@inject PageHeaderService HeaderService
@layout MainLayout

<div class="max-w-4xl space-y-12 pb-12">
    <!-- Section: Appearance -->
    <section class="space-y-6">
        <div class="flex flex-col gap-1">
            <h3 class="text-lg font-semibold tracking-tight">Theme</h3>
            <p class="text-sm text-muted-foreground">Select the appearance of the application.</p>
        </div>
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-2xl">
            <!-- Light Theme -->
            <button @onclick="() => SetTheme(false)" 
                    class="group relative flex flex-col gap-3 p-1 rounded-xl border-2 transition-all @(themeService.CurrentTheme == "light" ? "border-primary bg-primary/5" : "border-transparent hover:border-muted-foreground/20 bg-muted/50")">
                <div class="aspect-[16/10] w-full rounded-lg bg-white border border-border shadow-sm overflow-hidden flex flex-col">
                    <div class="h-4 bg-muted border-b border-border flex items-center px-2 gap-1">
                        <div class="w-1.5 h-1.5 rounded-full bg-border"></div>
                        <div class="w-10 h-1 bg-border rounded-full"></div>
                    </div>
                    <div class="flex-1 p-3 flex gap-2">
                        <div class="w-1/4 space-y-2">
                            <div class="h-2 w-full bg-muted rounded-full"></div>
                            <div class="h-2 w-2/3 bg-muted rounded-full"></div>
                        </div>
                        <div class="flex-1 space-y-2">
                            <div class="h-2 w-full bg-muted rounded-full opacity-50"></div>
                            <div class="h-2 w-4/5 bg-muted rounded-full opacity-50"></div>
                        </div>
                    </div>
                </div>
                <div class="flex items-center justify-between px-2 pb-1">
                    <span class="text-sm font-medium">Light</span>
                    @if (themeService.CurrentTheme == "light")
                    {
                        <div class="w-4 h-4 rounded-full bg-primary flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        </div>
                    }
                </div>
            </button>

            <!-- Dark Theme -->
            <button @onclick="() => SetTheme(true)" 
                    class="group relative flex flex-col gap-3 p-1 rounded-xl border-2 transition-all @(themeService.CurrentTheme == "dark" ? "border-primary bg-primary/5" : "border-transparent hover:border-muted-foreground/20 bg-muted/50")">
                <div class="aspect-[16/10] w-full rounded-lg bg-slate-950 border border-slate-800 shadow-sm overflow-hidden flex flex-col">
                     <div class="h-4 bg-slate-900 border-b border-slate-800 flex items-center px-2 gap-1">
                        <div class="w-1.5 h-1.5 rounded-full bg-slate-800"></div>
                        <div class="w-10 h-1 bg-slate-800 rounded-full"></div>
                    </div>
                    <div class="flex-1 p-3 flex gap-2">
                        <div class="w-1/4 space-y-2">
                            <div class="h-2 w-full bg-slate-900 rounded-full"></div>
                            <div class="h-2 w-2/3 bg-slate-900 rounded-full"></div>
                        </div>
                        <div class="flex-1 space-y-2">
                            <div class="h-2 w-full bg-slate-900 rounded-full opacity-50"></div>
                            <div class="h-2 w-4/5 bg-slate-900 rounded-full opacity-50"></div>
                        </div>
                    </div>
                </div>
                <div class="flex items-center justify-between px-2 pb-1">
                    <span class="text-sm font-medium">Dark</span>
                    @if (themeService.CurrentTheme == "dark")
                    {
                        <div class="w-4 h-4 rounded-full bg-primary flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        </div>
                    }
                </div>
            </button>
        </div>
    </section>

    <hr class="border-border" />

    <!-- Accent Color Section -->
    <section class="space-y-6">
        <div class="flex flex-col gap-1">
            <h3 class="text-lg font-semibold tracking-tight">Active Color</h3>
            <p class="text-sm text-muted-foreground">Change the primary accent color of the user interface.</p>
        </div>

        <div class="flex flex-wrap gap-3">
            @foreach (var color in PresetColors)
            {
                <button @onclick="() => SetPresetColor(color)" 
                        class="w-10 h-10 rounded-full border-2 transition-all p-0.5 @(themeService.CustomPrimaryColor == color ? "border-primary scale-110 shadow-lg ring-2 ring-primary/20" : "border-transparent hover:scale-110")"
                        style="background-color: transparent">
                    <div class="w-full h-full rounded-full shadow-inner flex items-center justify-center" style="background-color: @color">
                        @if (themeService.CustomPrimaryColor == color)
                        {
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="4" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                        }
                    </div>
                </button>
            }
            
            <div class="relative flex items-center justify-center h-10 w-10">
                <input type="color" 
                       id="colorPicker"
                       value="@(themeService.CustomPrimaryColor ?? "#2563eb")" 
                       @onchange="OnColorChanged"
                       class="absolute inset-0 w-full h-full opacity-0 cursor-pointer z-10" />
                <div class="w-10 h-10 rounded-full border-2 border-dashed border-muted-foreground/50 flex items-center justify-center hover:bg-muted transition-colors">
                     <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-muted-foreground"><path d="M12 5v14M5 12h14"/></svg>
                </div>
            </div>
        </div>

        <div class="flex items-center gap-4">
            <div class="bg-muted px-3 py-1.5 rounded-md border border-border flex items-center gap-2">
                <div class="w-3 h-3 rounded-full" style="background-color: @(themeService.CustomPrimaryColor ?? "#2563eb")"></div>
                <span class="text-xs font-mono font-medium uppercase tracking-wider">@(themeService.CustomPrimaryColor ?? "#2563eb")</span>
            </div>
            <button @onclick="ResetColor" class="text-xs text-muted-foreground hover:text-foreground transition-colors font-medium">
                Reset to default blue
            </button>
        </div>
    </section>
</div>

@code {
    private string[] PresetColors = new[] { 
        "#2563eb", "#dc2626", "#ea580c", "#d97706", "#16a34a", 
        "#0891b2", "#8b5cf6", "#d946ef", "#f43f5e", "#64748b" 
    };

    protected override void OnInitialized()
    {
        themeService.OnChange += StateHasChanged;
        HeaderService.SetHeader(
            "Appearance", 
            "Customize how StudyPlanner looks in your browser.", 
            themeService.CustomPrimaryColor ?? "#3B82F6",
            "<svg xmlns=\"http://www.w3.org/2000/svg\" width=\"24\" height=\"24\" viewBox=\"0 0 24 24\" fill=\"none\" stroke=\"currentColor\" stroke-width=\"2\" stroke-linecap=\"round\" stroke-linejoin=\"round\"><path d=\"M12 20a8 8 0 1 0 0-16 8 8 0 0 0 0 16Z\"/><path d=\"M12 14a2 2 0 1 0 0-4 2 2 0 0 0 0 4Z\"/><path d=\"M12 2v2\"/><path d=\"M12 20v2\"/><path d=\"m4.93 4.93 1.41 1.41\"/><path d=\"m17.66 17.66 1.41 1.41\"/><path d=\"M2 12h2\"/><path d=\"M20 12h2\"/><path d=\"m6.34 17.66-1.41 1.41\"/><path d=\"m19.07 4.93-1.41 1.41\"/></svg>"
        );
    }

    private async Task OnColorChanged(ChangeEventArgs e)
    {
        var color = e.Value?.ToString();
        if (!string.IsNullOrEmpty(color))
        {
            await themeService.SetPrimaryColorAsync(color);
        }
    }

    private async Task SetPresetColor(string color)
    {
        await themeService.SetPrimaryColorAsync(color);
    }

    private async Task ResetColor()
    {
        await themeService.SetPrimaryColorAsync(null);
    }

    private async Task SetTheme(bool isDark)
    {
        if ((isDark && themeService.CurrentTheme == "light") || (!isDark && themeService.CurrentTheme == "dark"))
        {
            await themeService.ToggleThemeAsync();
        }
    }

    public void Dispose()
    {
        themeService.OnChange -= StateHasChanged;
    }
}
