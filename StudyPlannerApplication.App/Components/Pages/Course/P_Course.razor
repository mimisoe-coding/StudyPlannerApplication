@page "/course"
@using StudyPlannerApplication.App.Components.Layout
@layout MainLayout
@inject SubjectService _subjectService
@inject CourseService _courseService
@rendermode InteractiveServer
@inject ILogger<P_Course> _logger

<div class="space-y-6 animate-in fade-in duration-500">
    <div class="flex items-center justify-between">
        <div>
            <h2 class="text-3xl font-extrabold tracking-tight">Courses</h2>
            <p class="text-muted-foreground mt-1">Track your progress and deadlines for each course.</p>
        </div>
        @if (_formType == EnumFormType.List)
        {
            <button class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors bg-primary text-primary-foreground hover:bg-primary/90 h-10 px-4 py-2 gap-2" @onclick=Create>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" x2="12" y1="5" y2="19"/><line x1="5" x2="19" y1="12" y2="12"/></svg>
                Add Course
            </button>
        }
    </div>

    @if (_formType == EnumFormType.List)
    {
        <div class="bg-card border border-border rounded-xl shadow-sm overflow-hidden text-sm">
            @if (_resModel?.Data?.CourseList?.Any() == true)
            {
                <div class="overflow-x-auto">
                    <table class="w-full text-left">
                        <thead class="bg-muted/50 border-b border-border text-muted-foreground font-medium">
                            <tr>
                                <th class="px-6 py-4">Sr No.</th>
                                <th class="px-6 py-4">Course Name</th>
                                <th class="px-6 py-4">Subject</th>
                                <th class="px-6 py-4">Status</th>
                                <th class="px-6 py-4">Due Date</th>
                                <th class="px-6 py-4 text-right">Action</th>
                            </tr>
                        </thead>
                        <tbody class="divide-y divide-border">
                            @{
                                int no = (ps.PageNo - 1) * ps.PageSize;
                                foreach (var item in _resModel.Data.CourseList)
                                {
                                    <tr class="hover:bg-muted/30 transition-colors">
                                        <td class="px-6 py-4 font-medium text-muted-foreground whitespace-nowrap">@(++no)</td>
                                        <td class="px-6 py-4 font-semibold whitespace-nowrap text-primary">@item.CourseName</td>
                                        <td class="px-6 py-4">
                                            <span class="inline-flex items-center rounded-full border border-primary/20 bg-primary/5 px-2.5 py-0.5 text-xs font-semibold text-primary">@item.SubjectName</span>
                                        </td>
                                        <td class="px-6 py-4">
                                            @if (item.Status == "Done")
                                            {
                                                <span class="inline-flex items-center rounded-full bg-green-500/10 px-2.5 py-0.5 text-xs font-semibold text-green-500 border border-green-500/20">
                                                    <svg class="mr-1 h-3 w-3" fill="currentColor" viewBox="0 0 8 8"><circle cx="4" cy="4" r="3" /></svg>
                                                    @item.Status
                                                </span>
                                            }
                                            else
                                            {
                                                <span class="inline-flex items-center rounded-full bg-yellow-500/10 px-2.5 py-0.5 text-xs font-semibold text-yellow-500 border border-yellow-500/20">
                                                    <svg class="mr-1 h-3 w-3 animate-pulse" fill="currentColor" viewBox="0 0 8 8"><circle cx="4" cy="4" r="3" /></svg>
                                                    @item.Status
                                                </span>
                                            }
                                        </td>
                                        <td class="px-6 py-4 font-medium @(item.DueDate < DateTime.Now ? "text-destructive" : "text-muted-foreground")">
                                            @item.DueDate.ToString("MMM dd, yyyy")
                                        </td>
                                        <td class="px-6 py-4 text-right whitespace-nowrap">
                                            <div class="flex items-center justify-end gap-2">
                                                <button class="h-8 w-8 inline-flex items-center justify-center rounded-md border border-input bg-background hover:bg-accent hover:text-accent-foreground transition-colors" title="Edit" @onclick="() => Edit(item.CourseId)">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                                                </button>
                                                <button class="h-8 w-8 inline-flex items-center justify-center rounded-md border border-primary/20 bg-primary/10 text-primary hover:bg-primary/20 transition-colors" title="Details" @onclick="() => Detail(item.CourseId)">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="12" x2="12" y1="16" y2="12"/><line x1="12" x2="12.01" y1="8" y2="8"/></svg>
                                                </button>
                                                <button class="h-8 w-8 inline-flex items-center justify-center rounded-md border border-destructive/20 bg-destructive/10 text-destructive hover:bg-destructive/20 transition-colors" title="Delete" @onclick="() => Delete(item.CourseId)">
                                                    <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 6h18"/><path d="M19 6v14c0 1-1 2-2 2H7c-1 0-2-1-2-2V6"/><path d="M8 6V4c0-1 1-2 2-2h4c1 0 2 1 2 2v2"/><line x1="10" x2="10" y1="11" y2="17"/><line x1="14" x2="14" y1="11" y2="17"/></svg>
                                                </button>
                                            </div>
                                        </td>
                                    </tr>
                                }
                            }
                        </tbody>
                    </table>
                </div>

                @if (count > 1)
                {
                    <div class="flex items-center justify-between px-6 py-4 border-t border-border bg-muted/20">
                        <div class="text-xs text-muted-foreground font-medium uppercase tracking-wider">
                            Page @ps.PageNo of @count
                        </div>
                        <div class="flex items-center gap-1">
                            <button disabled="@(ps.PageNo <= 1)" class="inline-flex items-center justify-center rounded-md w-8 h-8 text-sm font-medium transition-colors border border-input bg-background hover:bg-accent hover:text-accent-foreground disabled:opacity-50 disabled:pointer-events-none" @onclick="() => PageChanged(ps.PageNo - 1)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
                            </button>
                            
                            @for (int i = 1; i <= count; i++)
                            {
                                int pageIdx = i;
                                <button class="inline-flex items-center justify-center rounded-md w-8 h-8 text-sm font-medium transition-colors @(ps.PageNo == pageIdx ? "bg-primary text-primary-foreground hover:bg-primary/90" : "border border-input bg-background hover:bg-accent hover:text-accent-foreground")" @onclick="() => PageChanged(pageIdx)">
                                    @pageIdx
                                </button>
                            }

                            <button disabled="@(ps.PageNo >= count)" class="inline-flex items-center justify-center rounded-md w-8 h-8 text-sm font-medium transition-colors border border-input bg-background hover:bg-accent hover:text-accent-foreground disabled:opacity-50 disabled:pointer-events-none" @onclick="() => PageChanged(ps.PageNo + 1)">
                                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
                            </button>
                        </div>
                    </div>
                }
            }
            else
            {
                <div class="flex flex-col items-center justify-center py-20 text-center space-y-4">
                    <div class="w-16 h-16 bg-muted rounded-full flex items-center justify-center text-muted-foreground/50 border border-border/50">
                        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>
                    </div>
                    <div>
                        <p class="text-xl font-bold tracking-tight">No courses found</p>
                        <p class="text-muted-foreground mt-1 max-w-[250px]">Start your learning journey by adding a course.</p>
                    </div>
                </div>
            }
        </div>
    }

    @if (_formType != EnumFormType.List)
    {
        <div class="bg-card border border-border rounded-xl shadow-sm overflow-hidden animate-in slide-in-from-right-4 duration-300">
            <div class="px-6 py-4 border-b border-border bg-muted/30">
                <h3 class="font-bold text-lg">@(_formType.ToString()) Course</h3>
            </div>
            <div class="p-6">
                <div class="max-w-4xl space-y-8">
                    <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                        <div class="space-y-4">
                            <div class="space-y-2">
                                <label class="text-sm font-medium leading-none" for="subject">Subject</label>
                                <select id="subject" disabled="@visible" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 appearance-none" 
                                        @bind="_reqModel.SubjectCode">
                                    <option value="">Select Subject</option>
                                    @if (lstSubject != null)
                                    {
                                        foreach (var sub in lstSubject)
                                        {
                                            <option value="@sub.SubjectCode">@sub.SubjectName</option>
                                        }
                                    }
                                </select>
                            </div>
                            <div class="space-y-2">
                                <label class="text-sm font-medium leading-none" for="courseName">Course Name</label>
                                <input id="courseName" type="text" disabled=@visible class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50" @bind-value="_reqModel.CourseName" placeholder="e.g. Intro to Algebra">
                            </div>
                            <div class="space-y-2">
                                <label class="text-sm font-medium leading-none" for="status">Status</label>
                                <select id="status" disabled="@visible" class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50 appearance-none" 
                                        @bind="_reqModel.Status">
                                    <option value="">Select Status</option>
                                    @foreach (var status in lstStatus)
                                    {
                                        <option value="@status.Value">@status.Value</option>
                                    }
                                </select>
                            </div>
                        </div>
                        <div class="space-y-4">
                            <div class="space-y-2">
                                <label class="text-sm font-medium leading-none" for="dueDate">Due Date</label>
                                <input id="dueDate" type="date" disabled=@visible class="flex h-10 w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50" 
                                       @bind-value="_reqModel.DueDate" 
                                       @bind-value:format="yyyy-MM-dd"
                                       min="@DateTime.Today.ToString("yyyy-MM-dd")">
                            </div>
                            <div class="space-y-2">
                                <label class="text-sm font-medium leading-none" for="description">Description</label>
                                <textarea id="description" disabled=@visible class="flex min-h-[120px] w-full rounded-md border border-input bg-background px-3 py-2 text-sm ring-offset-background placeholder:text-muted-foreground focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-ring focus-visible:ring-offset-2 disabled:cursor-not-allowed disabled:opacity-50" @bind="_reqModel.Description" placeholder="Course syllabus or specific goal..."></textarea>
                            </div>
                        </div>
                    </div>

                    <div class="flex items-center gap-3 pt-6 border-t border-border">
                        <button @onclick=Back class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors border border-input bg-background hover:bg-accent hover:text-accent-foreground h-11 px-6">
                            Back to List
                        </button>
                        @if (_formType != EnumFormType.Detail)
                        {
                            <button class="inline-flex items-center justify-center rounded-md text-sm font-medium transition-colors bg-primary text-primary-foreground hover:bg-primary/90 h-11 px-10 shadow-sm" @onclick=Save>
                                @(_formType == EnumFormType.Register ? "Create Course" : "Save Changes")
                            </button>
                        }
                    </div>
                </div>
            </div>
        </div>
    }
</div>
